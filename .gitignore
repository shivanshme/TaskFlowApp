# .gitignore for ASP.NET Core / C# projects
# Build results
bin/
obj/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# OS generated files
.DS_Store
Thumbs.db

# Visual Studio Code
.vscode/

# Rider
.idea/

# Logs
*.log

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Publish output
wwwroot/

# Others
*.db
*.sqlite
*.pdb
*.mdb
*.opendb
*.pidb
*.svd
*.suo
*.userprefs
*.userosscache
*.sln.docstates

# Entity Framework Migrations
Migrations/*Designer.cs
Migrations/*Snapshot.cs

# Test results
TestResults/

# Npm packages
node_modules/

# Backup & temp files
*.bak
*.tmp
~$*

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper

# DotCover
*.dotCover

# Local secrets
secrets.json
